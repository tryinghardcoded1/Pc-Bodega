rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'paoloesteban75@gmail.com' ||
        request.auth.token.email == 'akolangpo@pcbodega.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 150 &&
             (!data.keys().has('email') || (data.email is string && data.email.size() <= 150)) &&
             (!data.keys().has('address') || (data.address is string && data.address.size() <= 1000)) &&
             (!data.keys().has('phone') || (data.phone is string && data.phone.size() <= 100)) &&
             data.updatedAt == request.time;
    }

    function isValidOrder(data) {
      return data.name is string && data.name.size() <= 150 &&
             data.email is string && data.email.size() <= 150 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.address is string && data.address.size() <= 1000 &&
             data.trackingNumber is string && data.trackingNumber.size() <= 100 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered'] &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.createdAt == request.time &&
             (data.userId == null || (data.userId is string && data.userId.size() <= 128)) &&
             (!data.keys().has('voucher') || (data.voucher is string || data.voucher == null)) &&
             (!data.keys().has('discount') || data.discount is number) &&
             (!data.keys().has('paymentProof') || (data.paymentProof is string && data.paymentProof.size() <= 5000));
    }

    function isValidChatThread(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 150 &&
             data.lastMessage is string && data.lastMessage.size() <= 1000 &&
             data.updatedAt == request.time &&
             (!data.keys().has('hasAdminUnread') || data.hasAdminUnread is bool) &&
             (!data.keys().has('hasUserUnread') || data.hasUserUnread is bool) &&
             (!data.keys().has('orderId') || (data.orderId is string && data.orderId.size() <= 128));
    }

    function isValidMessage(data) {
      return (data.keys().hasAny(['text', 'imageUrl'])) &&
             data.senderId is string && 
             data.createdAt == request.time &&
             (!data.keys().has('text') || (data.text is string && data.text.size() <= 10000)) &&
             (!data.keys().has('imageUrl') || (data.imageUrl is string && data.imageUrl.size() <= 5000000)) &&
             (!data.keys().has('isOrderSummary') || data.isOrderSummary is bool);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
    }

    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.trackingNumber != null);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.trackingNumber != null);
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow create: if isValidId(chatId) && isValidChatThread(incoming());
      allow get: if isAdmin() || (isSignedIn() && chatId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && chatId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      function canAccessThread() {
        return isAdmin() || (isSignedIn() && chatId == request.auth.uid);
      }
      allow create: if isValidId(messageId) && isValidMessage(incoming()) && canAccessThread();
      allow read: if canAccessThread();
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
