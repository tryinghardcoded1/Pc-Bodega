rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'paoloesteban75@gmail.com' ||
        request.auth.token.email == 'akolangpo@pcbodega.com'
      );
    }

    // Orders: Allow read if tracking number matches, or if admin/owner
    match /orders/{orderId} {
      allow create: if true;
      allow read: if true; // Just allow reading for now to ensure tracking works
      allow update: if true; // Simplify update for payment proofs
      allow delete: if isAdmin();
    }

    // Chats: Allow read/write if admin or if it's the user's own chat
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (chatId == request.auth.uid || isAdmin());
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (chatId == request.auth.uid || isAdmin());
      }
    }

    // Users and Admins
    match /users/{userId} {
      allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
