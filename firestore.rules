rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'paoloesteban75@gmail.com' ||
        request.auth.token.email == 'akolangpo@pcbodega.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Functions ---
    function isValidOrder(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'address', 'items', 'total', 'status', 'createdAt', 'trackingNumber']) &&
             data.name is string &&
             data.email is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'updatedAt']) &&
             data.displayName is string;
    }

    function isValidChatThread(data) {
      return data.keys().hasAll(['userId', 'userName', 'updatedAt']) &&
             data.userId is string &&
             data.userName is string;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'createdAt']) &&
             data.text is string &&
             data.senderId == request.auth.uid;
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read, write: if isSignedIn() && (request.auth.token.email == 'paoloesteban75@gmail.com' || request.auth.token.email == 'akolangpo@pcbodega.com' || isAdmin());
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || (resource != null && resource.data.trackingNumber != null);
      allow update, delete: if isAdmin();
    }

    // Chat Threads
    match /chats/{chatId} {
      allow create: if isValidId(chatId) && (incoming().userId == request.auth.uid || isAdmin());
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow update: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
    }

    // Chat Messages
    match /chats/{chatId}/messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid);
    }
  }
}
